# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=xcomm_hud

# 32-byte base64url-encoded master key used for cookie signing.
# Generate with:
#   python -c 'import secrets,base64;print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())'
XCOMM_HUD_SECRET_KEY=

# Initial admin credentials (only used when the user table is empty)
XCOMM_HUD_INITIAL_ADMIN_USER=admin
XCOMM_HUD_INITIAL_ADMIN_PASSWORD=changeme

# Object storage (MinIO in dev) for the document library. These defaults
# match the minio service in podman-compose.yml; the API creates the bucket
# on first use.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=xcomm-hud
